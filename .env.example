# IronCoach Konfiguration

# Sicherheit (mindestens 32 Zeichen!)
JWT_SECRET=dein-super-geheimer-jwt-schluessel-mindestens-32-zeichen-lang
SESSION_SECRET=dein-super-geheimer-session-schluessel-mindestens-32-zeichen

# Google OAuth (optional - für Google Login)
GOOGLE_CLIENT_ID=deine-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=dein-google-client-secret
GOOGLE_CALLBACK_URL=https://deine-domain.com/auth/google/callback

# Für lokale Entwicklung:
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Umgebung
NODE_ENV=production

# CORS (für Produktion)
ALLOWED_ORIGIN=https://deine-domain.com